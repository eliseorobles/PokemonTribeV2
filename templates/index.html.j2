<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Does the brain know which Pokémon cards are valuable?</title>
<meta name="description" content="A thought experiment: feeding Pokémon card images through Meta's TRIBE v2 fMRI model and seeing whether predicted brain activation correlates with market price.">
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Ccircle cx='32' cy='32' r='28' fill='%23ffcb05' stroke='%230e0e15' stroke-width='4'/%3E%3Cpath d='M4 32 H60' stroke='%230e0e15' stroke-width='4'/%3E%3Ccircle cx='32' cy='32' r='8' fill='%23fff' stroke='%230e0e15' stroke-width='4'/%3E%3C/svg%3E">
<style>
  :root {
    --bg: #0e0e15;
    --bg-elev: #161624;
    --bg-soft: #1f1f31;
    --fg: #f4f4f0;
    --fg-dim: #9ba0b3;
    --fg-muted: #6b7280;
    --accent-yellow: #ffcb05;
    --accent-blue: #3d7dca;
    --good: #4ade80;
    --bad: #f87171;
    --line: #2a2a3f;
    --serif: "Times New Roman", Georgia, serif;
    --sans: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", sans-serif;
    --mono: "SF Mono", "JetBrains Mono", Menlo, monospace;
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--fg);
    font-family: var(--sans);
    font-size: 16px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
  }
  a { color: var(--accent-blue); }
  a:hover { color: var(--accent-yellow); }
  main { max-width: 1180px; margin: 0 auto; padding: 0 1.25rem 6rem; }
  section { padding: 4rem 0 2rem; border-top: 1px solid var(--line); }
  section:first-of-type { border-top: 0; }
  h1, h2 { font-family: var(--serif); font-weight: 600; letter-spacing: -0.01em; }
  h1 { font-size: clamp(2rem, 5vw, 3.6rem); line-height: 1.05; margin: 0 0 1rem; }
  h2 { font-size: 1.6rem; margin: 0 0 1.25rem; }
  h3 { font-family: var(--sans); font-weight: 600; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--fg-dim); margin: 0 0 0.4rem; }
  .eyebrow { font-family: var(--mono); font-size: 0.75rem; color: var(--accent-yellow); text-transform: uppercase; letter-spacing: 0.18em; }
  .thesis { font-size: 1.15rem; color: var(--fg-dim); max-width: 60ch; }
  .verdict {
    background: linear-gradient(180deg, rgba(255,203,5,0.08), rgba(61,125,202,0.06));
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 2rem;
    margin-top: 2rem;
    font-size: 1.2rem;
  }
  .verdict strong { color: var(--accent-yellow); }
  .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; margin: 1.25rem 0 0; }
  .stat { background: var(--bg-elev); border: 1px solid var(--line); border-radius: 10px; padding: 0.9rem 1rem; }
  .stat .num { display: block; font-family: var(--mono); font-size: 1.4rem; color: var(--fg); }
  .stat .lbl { display: block; font-size: 0.78rem; color: var(--fg-muted); margin-top: 0.15rem; text-transform: uppercase; letter-spacing: 0.05em; }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start; }
  @media (max-width: 760px) { .two-col { grid-template-columns: 1fr; } }

  .roi-overlay-img { width: 100%; max-width: 760px; border-radius: 8px; background: white; }

  /* Cards grid + sort controls */
  .sort-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin: 0.75rem 0 1.25rem;
    font-family: var(--mono);
  }
  .sort-bar .lbl { color: var(--fg-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; margin-right: 0.5rem; }
  .sort-btn {
    background: var(--bg-elev);
    border: 1px solid var(--line);
    color: var(--fg-dim);
    font-family: var(--mono);
    font-size: 0.8rem;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .sort-btn:hover { color: var(--fg); border-color: var(--fg-muted); }
  .sort-btn.active { background: var(--accent-yellow); color: var(--bg); border-color: var(--accent-yellow); font-weight: 700; }
  .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.25rem; }
  .card {
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .card .img-wrap {
    aspect-ratio: 0.72;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .card .img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .card .body { padding: 0.7rem 0.85rem 0.85rem; }
  .card .name { font-size: 0.92rem; font-weight: 600; line-height: 1.25; color: var(--fg); }
  .card .meta { font-size: 0.72rem; color: var(--fg-muted); margin-top: 0.15rem; font-family: var(--mono); }
  .card .prices { display: flex; justify-content: space-between; margin-top: 0.55rem; gap: 0.5rem; font-family: var(--mono); font-size: 0.8rem; }
  .card .prices .actual { color: var(--fg); }
  .card .prices .predicted { color: var(--fg-dim); }
  .card .delta-row { display: flex; align-items: center; justify-content: space-between; margin-top: 0.35rem; font-size: 0.72rem; }
  .card .delta { font-family: var(--mono); padding: 0.12rem 0.45rem; border-radius: 4px; }
  .card .delta.up { background: rgba(74, 222, 128, 0.12); color: var(--good); }
  .card .delta.down { background: rgba(248, 113, 113, 0.12); color: var(--bad); }
  .card .heatmap {
    margin-top: 0.5rem;
    height: 56px;
    background:
      radial-gradient(ellipse at center, rgba(255,255,255,0.05), transparent 70%);
    background-color: #000;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card .heatmap img { max-width: 100%; max-height: 100%; }

  /* Brain's bets — two panel layout */
  .bets-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 1.5rem; }
  @media (max-width: 860px) { .bets-grid { grid-template-columns: 1fr; } }
  .bet-panel {
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 1.25rem 1.25rem 1rem;
  }
  .bet-panel.buy { border-color: rgba(74, 222, 128, 0.35); }
  .bet-panel.avoid { border-color: rgba(248, 113, 113, 0.35); }
  .bet-panel h3 { color: var(--fg); letter-spacing: 0.08em; font-size: 0.82rem; margin-bottom: 0.1rem; }
  .bet-panel .bet-sub { color: var(--fg-muted); font-size: 0.78rem; margin-bottom: 1rem; font-family: var(--mono); }
  .bet-list { display: flex; flex-direction: column; gap: 0.6rem; }
  .bet-row {
    display: grid;
    grid-template-columns: 48px 1fr auto;
    gap: 0.75rem;
    align-items: center;
    padding: 0.45rem 0.6rem;
    background: var(--bg);
    border-radius: 8px;
  }
  .bet-row .bet-thumb {
    width: 48px; height: 66px; border-radius: 4px;
    background: #000; display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .bet-row .bet-thumb img { max-width: 100%; max-height: 100%; object-fit: contain; }
  .bet-row .bet-info { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
  .bet-row .bet-name { font-size: 0.88rem; color: var(--fg); font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .bet-row .bet-meta { font-size: 0.72rem; color: var(--fg-muted); font-family: var(--mono); }
  .bet-row .bet-price {
    display: flex; flex-direction: column; align-items: flex-end; gap: 2px;
    font-family: var(--mono);
  }
  .bet-row .bet-actual { font-size: 0.82rem; color: var(--fg); }
  .bet-row .bet-implied { font-size: 0.74rem; color: var(--fg-dim); }
  .bet-row .bet-pct { font-size: 0.72rem; font-weight: 700; }
  .bet-row .bet-pct.up { color: var(--good); }
  .bet-row .bet-pct.down { color: var(--bad); }

  /* Rank badge in grid */
  .card .rank-badge {
    position: absolute; top: 8px; right: 8px;
    font-family: var(--mono); font-size: 0.7rem; font-weight: 700;
    padding: 0.12rem 0.45rem; border-radius: 4px;
    background: rgba(0,0,0,0.72); backdrop-filter: blur(6px);
  }
  .card .rank-badge.up { color: var(--good); }
  .card .rank-badge.down { color: var(--bad); }
  .card .img-wrap { position: relative; }

  /* Methodology */
  .methodology p { color: var(--fg-dim); max-width: 70ch; }
  .methodology ul { color: var(--fg-dim); max-width: 70ch; padding-left: 1.2rem; }
  .methodology li { margin: 0.4rem 0; }

  footer { padding: 3rem 0 1rem; color: var(--fg-muted); font-size: 0.8rem; text-align: center; }

  /* SVG chart axis text */
  svg text { fill: var(--fg-dim); font-family: var(--mono); font-size: 11px; }
  svg .axis-line { stroke: var(--line); stroke-width: 1; }
  svg .grid-line { stroke: var(--line); stroke-width: 1; stroke-dasharray: 2 3; opacity: 0.6; }
  svg .bar-pos { fill: var(--good); }
  svg .bar-neg { fill: var(--bad); }
  svg .bar-label { fill: var(--fg); }
  svg .dot { fill: var(--accent-yellow); fill-opacity: 0.85; }
  svg .reg-line { stroke: var(--accent-blue); stroke-width: 2; stroke-dasharray: 4 3; }
</style>
</head>
<body>
<main>

<section>
  <p class="eyebrow">a thought experiment</p>
  <h1>Does the human brain<br>know which Pokémon&nbsp;cards<br>are valuable?</h1>
  <p class="thesis">
    Each card in my Collectr portfolio was fed through
    <a href="https://github.com/facebookresearch/tribev2">TRIBE v2</a>,
    Meta's foundation model that predicts what a human brain would do when looking
    at an image. Then I asked whether the predicted brain activation correlates with
    what the card sells for.
  </p>

  <div class="verdict">
    {{ verdict | safe }}
  </div>

  <div class="stat-grid">
    <div class="stat"><span class="num">{{ n_cards }}</span><span class="lbl">cards analyzed</span></div>
    <div class="stat"><span class="num">{{ n_rois }}</span><span class="lbl">brain regions</span></div>
    <div class="stat"><span class="num">{{ "%+.2f"|format(loo_r2_real) }}</span><span class="lbl">held-out R²</span></div>
    <div class="stat"><span class="num">{{ "%.0f"|format(real_percentile_in_null) }}<span style="color:var(--fg-muted)">th</span></span><span class="lbl">vs shuffled controls</span></div>
  </div>
</section>

<section>
  <h2>Where does the brain fire most when shown my collection?</h2>
  <p class="thesis">Each region's color is its absolute correlation between predicted activation and log(price). Brighter = stronger relationship with what cards cost.</p>
  <img src="assets/roi_correlation.png" alt="Brain regions colored by correlation strength" class="roi-overlay-img">
</section>

<section class="two-col">
  <div>
    <h2>Top correlations</h2>
    <p class="thesis">The 10 brain regions whose predicted activation best tracks (or anti-tracks) log(price) across the collection.</p>
    {{ bars_svg | safe }}
  </div>
  <div>
    <h2>Activation vs price</h2>
    <p class="thesis">Each dot is a card. X = activation in <strong>{{ top_roi }}</strong> (the strongest single ROI). Y = log of market price. Dashed line is the OLS fit.</p>
    {{ scatter_svg | safe }}
  </div>
</section>

<section>
  <h2>The brain's bets</h2>
  <p class="thesis">
    For every card we ranked it two ways: <strong>market rank</strong> (1 = most expensive in the collection) and <strong>brain rank</strong> (1 = strongest predicted brain response).
    Cards the brain ranks much higher than the market are its <em>hidden gems</em>.
    Cards the market ranks much higher than the brain are its <em>skeptics</em>.
    Implied price = the actual market price at the brain's ranked position — a more honest projection than the log-regression's dollar output (which compresses everything toward the mean).
    <br><span style="color:var(--fg-muted); font-size:0.85rem;">Of {{ n_total }} priced cards, {{ n_undervalued }} land in "brain likes it more" and {{ n_overvalued }} in "market likes it more" (|rank diff| ≥ 30).</span>
  </p>
  <div class="bets-grid">
    <div class="bet-panel buy">
      <h3 style="color: var(--good);">HIDDEN GEMS</h3>
      <div class="bet-sub">brain ranks these higher than the market does</div>
      <div class="bet-list">
      {% for c in undervalued %}
        <div class="bet-row">
          <div class="bet-thumb">{% if c.image %}<img src="{{ c.image_url_rel }}" alt="">{% endif %}</div>
          <div class="bet-info">
            <div class="bet-name">{{ c.name | truncate(34, true) }}</div>
            <div class="bet-meta">market #{{ c.market_rank }} · brain #{{ c.brain_rank }} · {{ c.set_code or "—" }}</div>
          </div>
          <div class="bet-price">
            <span class="bet-actual">${{ "%.2f"|format(c.actual_price) }}</span>
            <span class="bet-implied">implied ${{ "%.2f"|format(c.implied_price) }}</span>
            <span class="bet-pct up">+{{ "%.0f"|format(c.implied_pct) }}%</span>
          </div>
        </div>
      {% endfor %}
      {% if not undervalued %}
      <div class="bet-sub" style="text-align:center; padding:0.5rem 0;">no cards met the threshold this run</div>
      {% endif %}
      </div>
    </div>

    <div class="bet-panel avoid">
      <h3 style="color: var(--bad);">MARKET KNOWS BEST</h3>
      <div class="bet-sub">market ranks these higher than the brain does</div>
      <div class="bet-list">
      {% for c in overvalued %}
        <div class="bet-row">
          <div class="bet-thumb">{% if c.image %}<img src="{{ c.image_url_rel }}" alt="">{% endif %}</div>
          <div class="bet-info">
            <div class="bet-name">{{ c.name | truncate(34, true) }}</div>
            <div class="bet-meta">market #{{ c.market_rank }} · brain #{{ c.brain_rank }} · {{ c.set_code or "—" }}</div>
          </div>
          <div class="bet-price">
            <span class="bet-actual">${{ "%.2f"|format(c.actual_price) }}</span>
            <span class="bet-implied">implied ${{ "%.2f"|format(c.implied_price) }}</span>
            <span class="bet-pct down">{{ "%.0f"|format(c.implied_pct) }}%</span>
          </div>
        </div>
      {% endfor %}
      {% if not overvalued %}
      <div class="bet-sub" style="text-align:center; padding:0.5rem 0;">no cards met the threshold this run</div>
      {% endif %}
      </div>
    </div>
  </div>
</section>

<section>
  <h2>Every card, ranked by brain-vs-market disagreement</h2>
  <p class="thesis">Each card shows its market rank (1 = most expensive of {{ n_total }}) and how the brain ranks it. The corner badge is the rank delta — positive (green) means the brain likes this card more than the market does.</p>
  <div class="sort-bar" id="sort-bar">
    <span class="lbl">Sort by</span>
    <button class="sort-btn active" data-sort="disagreement">|disagreement|</button>
    <button class="sort-btn" data-sort="price-desc">price ↓</button>
    <button class="sort-btn" data-sort="price-asc">price ↑</button>
    <button class="sort-btn" data-sort="brain-top">brain's top picks</button>
    <button class="sort-btn" data-sort="biggest-gems">biggest gems ↑</button>
  </div>
  <div class="cards-grid" id="cards-grid">
  {% for c in cards_sorted %}
    <div class="card"
         data-price="{{ c.actual_price }}"
         data-rank-diff="{{ c.rank_diff or 0 }}"
         data-brain-rank="{{ c.brain_rank or 9999 }}"
         data-market-rank="{{ c.market_rank or 9999 }}"
         data-implied-pct="{{ c.implied_pct or 0 }}">
      <div class="img-wrap">
        {% if c.image %}<img src="{{ c.image_url_rel }}" alt="{{ c.name }}" loading="lazy">{% endif %}
        {% if c.rank_diff is defined %}
        <div class="rank-badge {{ 'up' if c.rank_diff >= 0 else 'down' }}">{{ '+' if c.rank_diff >= 0 else '' }}{{ c.rank_diff }}</div>
        {% endif %}
      </div>
      <div class="body">
        <div class="name">{{ c.name | truncate(58, true) }}</div>
        <div class="meta">{{ c.set_code or "—" }}</div>
        <div class="prices">
          <span class="actual">${{ "%.2f"|format(c.actual_price) }}</span>
          <span class="predicted">implied ${{ "%.2f"|format(c.implied_price) }}</span>
        </div>
        <div class="delta-row">
          <span>market #{{ c.market_rank }} · brain #{{ c.brain_rank }}</span>
          <span class="delta {{ 'up' if c.implied_pct >= 0 else 'down' }}">{{ '+' if c.implied_pct >= 0 else '' }}{{ "%.0f"|format(c.implied_pct) }}%</span>
        </div>
        {% if c.has_heatmap %}
        <div class="heatmap"><img src="assets/heatmaps/{{ c.id }}.png" alt="brain heatmap"></div>
        {% endif %}
      </div>
    </div>
  {% endfor %}
  </div>
</section>

<section class="methodology">
  <h2>Methodology &amp; caveats</h2>
  <p><strong>Pipeline.</strong> Card catalog images were scraped from a personal Collectr portfolio (catalog product images, not user photos). Each image was wrapped as a 2-second silent MP4 — TRIBE v2's public API takes video, not images directly — and passed to <code>TribeModel.predict</code>. The output is a per-second prediction of the BOLD signal across the ~20,484 vertices of the fsaverage5 cortical mesh. We averaged across timesteps, then partitioned vertices into 14 anatomical regions (occipital / parietal / temporal / sensorimotor / frontal / prefrontal / cingulate × L/R) using each vertex's 3D coordinate, and took the mean activation inside each region.</p>
  <p><strong>Statistics.</strong> Per-region Pearson r against log(market_price), then a Ridge regression from the 14-dim ROI vector onto log(price), with leave-one-out cross-validation. As a control, we permuted the price column {{ n_shuffles }} times and re-ran the same LOO regression to get a null distribution of held-out R². The headline number is where the real R² falls in that distribution.</p>
  <ul>
    <li><strong>Correlation isn't causation.</strong> Even if predicted neural activation tracks price, the brain doesn't <em>set</em> Pokémon prices — TCG market mechanics do. The honest framing is: visual features that drive predicted brain activation also happen to be visual features that the secondary market values.</li>
    <li><strong>Small N.</strong> A few dozen cards is too few to make confident claims. The shuffle control protects against false positives, but real signal could still be a quirk of one collection.</li>
    <li><strong>TRIBE v2 was not trained on Pokémon cards</strong> — it was trained on naturalistic media (videos, podcasts, images). Its brain predictions on a static card image are out-of-distribution.</li>
    <li><strong>Static-image artifact.</strong> Wrapping a still image as a 2-second silent video means the audio and language extractors see nothing. Only the V-JEPA2 visual stream contributes.</li>
  </ul>
  <p>Built with <a href="https://github.com/facebookresearch/tribev2">TRIBE v2</a> (Meta, CC BY-NC). Pipeline source: see the <code>tribev2 demo</code> repo. This page contains a single ~30-line vanilla JS snippet for sort reordering — no framework, no tracking, no analytics.</p>
</section>

<script>
(function () {
  var grid = document.getElementById('cards-grid');
  var bar = document.getElementById('sort-bar');
  if (!grid || !bar) return;
  var cards = Array.from(grid.children);
  var sorters = {
    'disagreement':  function (a, b) { return Math.abs(b.d.rankDiff) - Math.abs(a.d.rankDiff); },
    'price-desc':    function (a, b) { return b.d.price - a.d.price; },
    'price-asc':     function (a, b) { return a.d.price - b.d.price; },
    'brain-top':     function (a, b) { return a.d.brainRank - b.d.brainRank; },
    'biggest-gems':  function (a, b) { return b.d.rankDiff - a.d.rankDiff; }
  };
  cards.forEach(function (c) {
    c.d = {
      price: parseFloat(c.dataset.price) || 0,
      rankDiff: parseInt(c.dataset.rankDiff, 10) || 0,
      brainRank: parseInt(c.dataset.brainRank, 10) || 9999,
      marketRank: parseInt(c.dataset.marketRank, 10) || 9999,
      impliedPct: parseFloat(c.dataset.impliedPct) || 0
    };
  });
  bar.addEventListener('click', function (e) {
    var btn = e.target.closest('.sort-btn');
    if (!btn) return;
    var key = btn.dataset.sort;
    if (!sorters[key]) return;
    bar.querySelectorAll('.sort-btn').forEach(function (b) { b.classList.toggle('active', b === btn); });
    var sorted = cards.slice().sort(sorters[key]);
    var frag = document.createDocumentFragment();
    sorted.forEach(function (c) { frag.appendChild(c); });
    grid.appendChild(frag);
  });
})();
</script>

</main>

<footer>
  Generated {{ generated_at }} · {{ n_cards }} cards · TRIBE v2 (CC BY-NC) · No tracking, no analytics.
</footer>

</body>
</html>
